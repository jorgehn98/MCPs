# LinkedIn Developer App credentials
# Get these from https://developer.linkedin.com/
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# OAuth callback URL — must match exactly what you registered in the LinkedIn app
LINKEDIN_REDIRECT_URI=http://localhost:3000/callback

# LinkedIn API version (YYYYMM format) — update yearly
LINKEDIN_API_VERSION=202601

# Port for the OAuth callback server (only used during auth setup)
AUTH_PORT=3000
