# X (Twitter) API Credentials
# Get these from https://developer.twitter.com/en/portal/dashboard

# OAuth 2.0 App credentials (required for posting and user-specific actions)
X_CLIENT_ID=your_client_id_here
X_CLIENT_SECRET=your_client_secret_here   # optional for public clients (PKCE)

# App-only Bearer Token (required for reading public data without user context)
X_BEARER_TOKEN=your_bearer_token_here

# OAuth callback URL — must match exactly what you set in the developer portal
X_REDIRECT_URI=http://localhost:3000/callback

# Auth server port (default: 3000)
AUTH_PORT=3000
